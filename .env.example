NODE_ENV=development
PORT=6000
FRONTEND_URL=http://127.0.0.1:6001

# Database
DATABASE_URL=postgresql://tokensee:tokensee_dev_password@localhost:5432/tokensee

# Redis
REDIS_URL=redis://localhost:6379

# RPC Providers
# Alchemy: https://dashboard.alchemy.com — Ethereum mainnet
# IMPORTANT: Free Alchemy tier has 30M CUs/month. For 7-chain scanning, consider:
#   - Using free public RPCs for L2/BSC chains (save CUs for ETH)
#   - Batch requests to reduce per-call CU overhead
#   - See docs/cn/development.md for cost optimization tips
ALCHEMY_API_KEY=rDFp5NY2RrKi2i7rqIPKl4KBOY3DF4XU

# QuickNode: https://dashboard.quicknode.com — BSC + ETH failover
# QUICKNODE_ETH_URL=  (not needed, Alchemy covers ETH)
# QUICKNODE_BSC_URL=  (BSC will use public RPC for now)

# Alchemy URLs for L2 chains (optional — defaults to ALCHEMY_API_KEY if omitted)
# These override the default Alchemy endpoint for each chain
ALCHEMY_ARBITRUM_URL=https://arb-mainnet.g.alchemy.com/v2/rDFp5NY2RrKi2i7rqIPKl4KBOY3DF4XU
ALCHEMY_POLYGON_URL=https://polygon-mainnet.g.alchemy.com/v2/rDFp5NY2RrKi2i7rqIPKl4KBOY3DF4XU
ALCHEMY_BASE_URL=https://base-mainnet.g.alchemy.com/v2/rDFp5NY2RrKi2i7rqIPKl4KBOY3DF4XU
ALCHEMY_OPTIMISM_URL=https://opt-mainnet.g.alchemy.com/v2/rDFp5NY2RrKi2i7rqIPKl4KBOY3DF4XU
ALCHEMY_AVALANCHE_URL=

# Custom public RPC URLs (optional — overrides built-in public endpoints)
# Use these if the default public RPCs are blocked or slow in your region.
# BSCScan API key — for BSC token balances
BSCSCAN_API_KEY=

# External APIs (optional - extends rate limits)
COINGECKO_API_KEY=

# WhaleMonitor — minimum USD value to trigger an alert (default: 1,000,000)
WHALE_USD_THRESHOLD=1000000

# Webhooks
# Keep this true in local development if you want to target localhost/private IPs.
ALLOW_PRIVATE_WEBHOOK_URLS=true

# Auth
API_KEY_SALT=change_me_to_random_32_byte_hex_string
