# ── 基础 ──────────────────────────────
NODE_ENV=production
PORT=8080
FRONTEND_URL=https://yourdomain.com

# ── 数据库 ────────────────────────────
# Docker 容器中运行，用户名/数据库名: tokensee
# 密码在部署时通过交互式输入，或在 .env.production 中设置
DATABASE_URL=postgresql://tokensee:your_postgres_password@127.0.0.1:5432/tokensee

# ── Redis ─────────────────────────────
# Docker 容器中运行（无密码）
REDIS_URL=redis://127.0.0.1:6379
# 如果设置了 Redis 密码:
# REDIS_URL=redis://:your_redis_password@127.0.0.1:6379

# ── RPC 节点 ─────────────────────────
# 请访问 https://dashboard.alchemy.com 申请 API Key
# Ethereum 主网推荐使用 Alchemy（最稳定）
# BSC/L2 链可以使用免费公开 RPC 节省 Alchemy 调用配额
ALCHEMY_API_KEY=your_alchemy_api_key_here

# BSC QuickNode（可选，Alchemy 不支持 BSC）
# QUICKNODE_BSC_URL=https://...

# L2 链 Alchemy 端点（可选，不填则使用 ALCHEMY_API_KEY 的默认端点）
# ALCHEMY_ARBITRUM_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
# ALCHEMY_POLYGON_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
# ALCHEMY_BASE_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
# ALCHEMY_OPTIMISM_URL=https://opt-mainnet.g.alchemy.com/v2/YOUR_KEY

# ── 外部 API（可选）──────────────────
# Etherscan — 用于 EnrichmentService
ETHERSCAN_API_KEY=
# CoinGecko — 价格数据
COINGECKO_API_KEY=
# BSCScan — BSC 代币余额查询
BSCSCAN_API_KEY=

# ── 认证 ──────────────────────────────
# 生产环境务必使用强随机值，至少 32 字符
# 生成方式: openssl rand -hex 32
API_KEY_SALT=generate_a_strong_random_string_at_least_32_chars_here

# ── 巨鲸监控 ─────────────────────────
# 触发大额转账告警的 USD 阈值（默认 1,000,000 即 $100万）
WHALE_USD_THRESHOLD=1000000

# ── Webhook 安全 ─────────────────────
# 生产环境设为 false，阻止 webhook 回调到内网/本地地址
ALLOW_PRIVATE_WEBHOOK_URLS=false
