NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://tokensee:tokensee_dev_password@localhost:5432/tokensee

# Redis
REDIS_URL=redis://localhost:6379

# RPC Providers
# Alchemy: https://dashboard.alchemy.com — Ethereum mainnet
ALCHEMY_API_KEY=your_alchemy_api_key_here

# QuickNode: https://dashboard.quicknode.com — BSC + ETH failover
QUICKNODE_ETH_URL=https://your-eth-endpoint.quiknode.pro/your-token/
QUICKNODE_BSC_URL=https://your-bsc-endpoint.quiknode.pro/your-token/

# Alchemy URLs for L2 chains (optional — defaults to ALCHEMY_API_KEY if omitted)
# These override the default Alchemy endpoint for each chain
ALCHEMY_ARBITRUM_URL=https://arb-mainnet.g.alchemy.com/v2/your_alchemy_api_key_here
ALCHEMY_POLYGON_URL=https://polygon-mainnet.g.alchemy.com/v2/your_alchemy_api_key_here
ALCHEMY_BASE_URL=https://base-mainnet.g.alchemy.com/v2/your_alchemy_api_key_here

# BSCScan API key — for BSC token balances
BSCSCAN_API_KEY=

# External APIs (optional - extends rate limits)
COINGECKO_API_KEY=

# Auth
API_KEY_SALT=change_me_to_random_32_byte_hex_string
