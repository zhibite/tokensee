{
  "name": "tokensee",
  "version": "0.1.0",
  "description": "Invisible Infrastructure — unified API layer for multi-chain blockchain data",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "tsx scripts/migrate.ts",
    "import-labels": "tsx scripts/import-labels.ts",
    "import-labels:dry": "tsx scripts/import-labels.ts -- --dry-run"
  },
  "keywords": ["blockchain", "web3", "api", "multichain"],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.5",
    "@types/pg": "^8.18.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
